# Local development (SQLite file)
DATABASE_URL="file:./dev.db"

# Production on Vercel — use Turso (free SQLite cloud)
# 1) Create account at https://turso.tech
# 2) Create database: turso db create dhirgham-cnc
# 3) Get URL: turso db show dhirgham-cnc --url
# 4) Create token: turso db tokens create dhirgham-cnc
# TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Auth secret for admin sessions (generate a random 32+ char string)
AUTH_SECRET="change-this-to-a-long-random-secret-key"

# Default admin account (created on first seed)
ADMIN_EMAIL="admin@darghamcnc.com"
ADMIN_PASSWORD="Admin@123456"
ADMIN_NAME="مدير النظام"

# Google Gemini API key (server-side only — never expose to client)
# Get key from: https://aistudio.google.com/apikey
# Then enable AI in Admin → Site Settings
# Or set AI_ENABLED=true on Vercel to force-enable when a key is present
GEMINI_API_KEY=""
AI_ENABLED=""

# WhatsApp notifications via CallMeBot (https://www.callmebot.com/blog/free-api-whatsapp-messages/)
# 1) Send "I allow callmebot to send me messages" to +34 644 44 71 67 on WhatsApp
# 2) Copy your API key and paste it below
# 3) Set your WhatsApp number in Admin → Site Settings
WHATSAPP_NOTIFY_API_KEY=""
